{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "tiered-practice-ai-review",
  "main": "ai-review-worker.js",
  "compatibility_date": "2026-06-16",
  "compatibility_flags": ["nodejs_compat_v2"],
  "vars": {
    "AI_REVIEW_BASE_URL": "https://api.deepseek.com",
    "AI_REVIEW_MODEL": "deepseek-v4-pro",
    "AI_REVIEW_REASONING_EFFORT": "high",
    "AI_REVIEW_MAX_TOKENS": "320",
    "AI_REVIEW_TIMEOUT_SECONDS": "25",
    "AI_TRANSCRIBE_BASE_URL": "https://api.openai.com/v1",
    "AI_TRANSCRIBE_MODEL": "whisper-1",
    "ALLOWED_ORIGINS": "https://clark58.github.io,http://127.0.0.1:4174,http://127.0.0.1:4175,http://localhost:4174"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
